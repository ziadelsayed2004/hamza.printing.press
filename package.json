{
  "name": "bookstore-manager-modernized",
  "version": "1.0.0",
  "description": "Modernized Bookstore Manager System",
  "main": "app.js",
  "type": "commonjs",
  "scripts": {
    "start": "node app.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon app.js",
    "dev:client": "npm run dev --prefix client",
    "build": "npm run build --prefix client && node scripts/copy-client-build.js",
    "db:migrate": "node server/db/migrate.js",
    "db:reset": "node server/db/reset.js",
    "backup": "node scripts/backup-db.js",
    "test": "node scripts/test_runner.js",
    "smoke": "node scripts/smoke_test.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "html-pdf-node": "^1.0.8",
    "luxon": "^3.5.0",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "eslint": "^9.16.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.0.0"
  }
}
