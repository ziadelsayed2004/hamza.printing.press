{
  "name": "bookstore-manager-modernized",
  "version": "1.0.0",
  "description": "Modernized Bookstore Manager System",
  "main": "app.js",
  "type": "commonjs",
  "scripts": {
    "postinstall": "npm install --prefix client",
    "setup": "npm run db:reset && npm run build",
    "start": "node app.js",
    "dev": "concurrently \"nodemon app.js\" \"npm run dev --prefix client\"",
    "build": "npm run build --prefix client",
    "prod": "npm run db:migrate && npm run build && node app.js",
    "db:migrate": "node server/db/migrate.js",
    "db:reset": "node server/db/reset.js",
    "backup": "node scripts/backup-db.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "html-pdf-node": "^1.0.8",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "eslint": "^9.16.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.0.0"
  }
}
